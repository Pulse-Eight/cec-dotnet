<Project Sdk="Microsoft.NET.Sdk">

  <!--
    cec-tray: the Windows-only WinForms front-end for libCEC. Ported from the old
    .NET Framework project to net8.0-windows so it references the single unified
    pure-C# LibCecSharp assembly (no more .NET Framework flavour).

    Generated from LibCECTray.csproj.in by cmake - edit the .in, not the .csproj.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>LibCECTray</RootNamespace>
    <AssemblyName>cec-tray</AssemblyName>
    <ApplicationIcon>..\..\project\p8_logo.ico</ApplicationIcon>
    <Platforms>x86;x64</Platforms>
    <!-- keep using the cmake-generated Properties\AssemblyInfo.cs -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Version>8.0.0.0</Version>
    <Company>Pulse-Eight Limited</Company>
    <Authors>Lars Op den Kamp</Authors>
    <Product>libCEC</Product>
    <Copyright>Copyright (c) Pulse-Eight Limited 2011-2025</Copyright>
    <NoWarn>$(NoWarn);CA1416</NoWarn>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>..\..\..\..\build\$(Configuration)\$(Platform)\net8.0\</OutputPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Platform)' == 'x64'">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Platform)' == 'x86'">
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="LibCecSharp">
      <HintPath>..\..\..\..\build\$(Configuration)\$(Platform)\net8.0\LibCecSharp.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
